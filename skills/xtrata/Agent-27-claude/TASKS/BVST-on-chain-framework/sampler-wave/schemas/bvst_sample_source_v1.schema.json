{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "bvst.sample-source/v1",
  "title": "BVST Sample Source Manifest v1",
  "type": "object",
  "required": [
    "schema",
    "name",
    "sample_id",
    "plugin_targets",
    "audio_leaf",
    "playback",
    "runtime_source"
  ],
  "properties": {
    "schema": { "const": "bvst.sample-source/v1" },
    "name": { "type": "string" },
    "sample_id": { "type": "string" },
    "release_scope": { "type": "string" },
    "plugin_targets": {
      "type": "array",
      "items": { "type": "string" },
      "minItems": 1
    },
    "audio_leaf": {
      "type": "object",
      "required": ["name", "path", "mime_type", "sha256", "bytes", "chunks", "route"],
      "properties": {
        "name": { "type": "string" },
        "token_id": { "type": ["integer", "null"] },
        "txid": { "type": ["string", "null"] },
        "block_height": { "type": ["integer", "null"] },
        "path": { "type": "string" },
        "mime_type": { "type": "string" },
        "sha256": { "type": "string" },
        "bytes": { "type": "integer", "minimum": 1 },
        "chunks": { "type": "integer", "minimum": 1 },
        "route": { "enum": ["helper", "staged"] }
      },
      "additionalProperties": true
    },
    "playback": {
      "type": "object",
      "required": ["root_note", "loop_start_pct", "loop_end_pct", "channels", "sample_rate", "duration_seconds"],
      "properties": {
        "root_note": { "type": "integer" },
        "loop_start_pct": { "type": "number", "minimum": 0, "maximum": 1 },
        "loop_end_pct": { "type": "number", "minimum": 0, "maximum": 1 },
        "one_shot": { "type": "boolean" },
        "channels": { "type": "integer", "minimum": 1 },
        "sample_rate": { "type": "integer", "minimum": 1 },
        "duration_seconds": { "type": "number", "exclusiveMinimum": 0 }
      },
      "additionalProperties": true
    },
    "runtime_source": {
      "type": "object",
      "required": ["id", "label", "content_url", "content_url_template"],
      "properties": {
        "id": { "type": "string" },
        "label": { "type": "string" },
        "content_url": { "type": ["string", "null"] },
        "content_url_template": { "type": "string" }
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": true
}
