{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "bvst.patch/v1",
  "title": "BVST Patch v1",
  "type": "object",
  "oneOf": [
    { "$ref": "#/$defs/PatchDocument" },
    { "$ref": "#/$defs/BvstInitConfig" }
  ],
  "$defs": {
    "PatchDocument": {
      "type": "object",
      "required": ["schema", "config"],
      "properties": {
        "schema": { "const": "bvst.patch/v1" },
        "config": { "$ref": "#/$defs/BvstInitConfig" },
        "meta": {
          "type": "object",
          "properties": {
            "name": { "type": "string" },
            "description": { "type": "string" },
            "author": { "type": "string" },
            "inherits": { "type": "string" }
          },
          "additionalProperties": true
        }
      },
      "additionalProperties": false
    },
    "BvstInitConfig": {
      "type": "object",
      "required": ["name", "modules"],
      "properties": {
        "name": { "type": "string" },
        "containerId": { "type": "string" },
        "visualizer": { "enum": ["off", "scope", "spectrum"] },
        "keyboard": {
          "oneOf": [
            { "type": "boolean" },
            {
              "type": "object",
              "properties": {
                "startNote": { "type": "integer" },
                "numKeys": { "type": "integer" },
                "responsive": { "type": "boolean" }
              },
              "additionalProperties": true
            }
          ]
        },
        "sequencer": {
          "oneOf": [
            { "type": "boolean" },
            {
              "type": "object",
              "properties": {
                "type": { "enum": ["step", "grid", "arp"] },
                "steps": { "type": "integer" },
                "rows": { "type": "integer" },
                "paramMap": { "type": "object", "additionalProperties": true }
              },
              "additionalProperties": true
            }
          ]
        },
        "sampler": { "$ref": "#/$defs/SamplerConfig" },
        "midiMap": { "type": "object", "additionalProperties": true },
        "defaultPreset": { "type": "string" },
        "profiles": {
          "type": "object",
          "additionalProperties": {
            "type": "object",
            "additionalProperties": true
          }
        },
        "modules": {
          "type": "array",
          "items": { "$ref": "#/$defs/Module" }
        },
        "presets": {
          "type": "object",
          "additionalProperties": {
            "type": "object",
            "additionalProperties": { "type": ["number", "integer"] }
          }
        }
      },
      "additionalProperties": true
    },
    "Module": {
      "type": "object",
      "required": ["name", "controls"],
      "properties": {
        "name": { "type": "string" },
        "cols": { "type": "integer" },
        "controls": {
          "type": "array",
          "items": { "$ref": "#/$defs/Control" }
        }
      },
      "additionalProperties": true
    },
    "Control": {
      "type": "object",
      "required": ["id", "param", "type"],
      "properties": {
        "id": { "type": "string" },
        "param": { "type": "integer" },
        "type": { "enum": ["knob", "slider", "select", "switch", "button"] },
        "label": { "type": "string" },
        "text": { "type": "string" },
        "min": { "type": "number" },
        "max": { "type": "number" },
        "step": { "type": "number" },
        "val": { "type": ["number", "integer"] },
        "default": { "type": ["number", "integer"] },
        "curve": { "enum": ["linear", "log"] },
        "orientation": { "enum": ["horizontal", "vertical"] },
        "options": { "type": "array", "items": { "type": "string" } }
      },
      "additionalProperties": true
    },
    "SamplerSource": {
      "type": "object",
      "required": ["url"],
      "properties": {
        "id": { "type": "string" },
        "label": { "type": "string" },
        "url": { "type": "string" },
        "rootNote": { "type": "integer" },
        "loopStart": { "type": "number", "minimum": 0, "maximum": 1 },
        "loopEnd": { "type": "number", "minimum": 0, "maximum": 1 }
      },
      "additionalProperties": true
    },
    "SamplerConfig": {
      "type": "object",
      "properties": {
        "enabled": { "type": "boolean" },
        "showVisualizer": { "type": "boolean" },
        "runtimeProfile": { "type": "string" },
        "sourcePolicy": {
          "enum": ["standalone-dev", "inscriptions-only", "declared-only"]
        },
        "allowFileDrop": { "type": "boolean" },
        "allowDataUrls": { "type": "boolean" },
        "maxSampleBytes": { "type": "integer", "minimum": 1 },
        "maxSampleSeconds": { "type": "number", "exclusiveMinimum": 0 },
        "source": { "type": "string" },
        "sources": {
          "type": "array",
          "items": { "$ref": "#/$defs/SamplerSource" }
        },
        "defaults": {
          "type": "object",
          "properties": {
            "playSpeed": { "type": "number" },
            "reverse": { "type": "boolean" },
            "loopStart": { "type": "number", "minimum": 0, "maximum": 1 },
            "loopEnd": { "type": "number", "minimum": 0, "maximum": 1 },
            "loopEnabled": { "type": "boolean" },
            "note": { "type": "integer" },
            "sliceGrid": { "type": "number", "minimum": 0 },
            "grainSize": { "type": "number", "minimum": 0 },
            "grainPos": { "type": "number", "minimum": 0, "maximum": 1 }
          },
          "additionalProperties": true
        }
      },
      "additionalProperties": true
    }
  }
}
