{
  "schema": "bvst.patch/v1",
  "meta": {
    "name": "BlueMarvinTwo",
    "description": "ARP 2600-inspired poly synth (Mk II)."
  },
  "config": {
    "name": "BlueMarvinTwo",
    "visualizer": "spectrum",
    "keyboard": { "startNote": 60, "numKeys": 25 },
    "modules": [
      {
        "name": "VCO 1",
        "cols": 1,
        "controls": [
          { "id": "vco1_wave", "param": 1, "type": "select", "options": ["Sine", "Saw", "Square", "Pulse", "Tri"], "val": 1, "label": "Wave" },
          { "id": "vco1_coarse", "label": "Coarse", "param": 2, "type": "knob", "min": -24, "max": 24, "val": 0, "step": 1 },
          { "id": "vco1_fine", "label": "Fine", "param": 3, "type": "knob", "min": -100, "max": 100, "val": 0, "step": 1 },
          { "id": "vco1_lvl", "label": "Lvl", "param": 10, "type": "knob", "min": 0, "max": 1, "val": 0.7, "step": 0.01 }
        ]
      },
      {
        "name": "VCO 2",
        "cols": 1,
        "controls": [
          { "id": "vco2_wave", "param": 4, "type": "select", "options": ["Sine", "Saw", "Square", "Pulse", "Tri"], "val": 2, "label": "Wave" },
          { "id": "vco2_coarse", "label": "Coarse", "param": 5, "type": "knob", "min": -24, "max": 24, "val": 0, "step": 1 },
          { "id": "vco2_fine", "label": "Fine", "param": 6, "type": "knob", "min": -100, "max": 100, "val": 5, "step": 1 },
          { "id": "vco2_lvl", "label": "Lvl", "param": 11, "type": "knob", "min": 0, "max": 1, "val": 0.7, "step": 0.01 }
        ]
      },
      {
        "name": "VCO 3",
        "cols": 1,
        "controls": [
          { "id": "vco3_wave", "param": 7, "type": "select", "options": ["Sine", "Saw", "Square", "Pulse", "Tri"], "val": 1, "label": "Wave" },
          { "id": "vco3_coarse", "label": "Coarse", "param": 8, "type": "knob", "min": -36, "max": 12, "val": -12, "step": 1 },
          { "id": "vco3_fine", "label": "Fine", "param": 9, "type": "knob", "min": -100, "max": 100, "val": 0, "step": 1 },
          { "id": "vco3_lvl", "label": "Lvl", "param": 12, "type": "knob", "min": 0, "max": 1, "val": 0.0, "step": 0.01 }
        ]
      },
      {
        "name": "VCF",
        "cols": 1,
        "controls": [
          { "id": "vcf_freq", "label": "Freq", "param": 13, "type": "knob", "min": 20, "max": 12000, "curve": "log", "val": 500, "step": 10 },
          { "id": "vcf_res", "label": "Res", "param": 14, "type": "knob", "min": 0, "max": 25, "val": 0, "step": 0.1 },
          { "id": "vcf_env", "label": "Env", "param": 15, "type": "knob", "min": 0, "max": 5000, "val": 1500, "step": 10 }
        ]
      },
      {
        "name": "Filter ADSR",
        "cols": 1,
        "controls": [
          { "id": "adsr_a", "label": "A", "param": 16, "type": "knob", "min": 0.001, "max": 2, "val": 0.01, "step": 0.01 },
          { "id": "adsr_d", "label": "D", "param": 17, "type": "knob", "min": 0.01, "max": 2, "val": 0.4, "step": 0.01 },
          { "id": "adsr_s", "label": "S", "param": 18, "type": "knob", "min": 0, "max": 1, "val": 0.2, "step": 0.01 },
          { "id": "adsr_r", "label": "R", "param": 19, "type": "knob", "min": 0.01, "max": 5, "val": 0.8, "step": 0.01 }
        ]
      },
      {
        "name": "Amp AR",
        "cols": 1,
        "controls": [
          { "id": "ar_a", "label": "A", "param": 20, "type": "knob", "min": 0.001, "max": 2, "val": 0.01, "step": 0.01 },
          { "id": "ar_r", "label": "R", "param": 21, "type": "knob", "min": 0.01, "max": 5, "val": 0.5, "step": 0.01 },
          { "id": "master_vol", "label": "Vol", "param": 22, "type": "knob", "min": 0, "max": 1, "val": 0.8, "step": 0.01 }
        ]
      }
