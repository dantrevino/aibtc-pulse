{
  "schema": "bvst.patch/v1",
  "meta": {
    "name": "NeonPoly",
    "description": "Poly synth patch."
  },
  "config": {
    "name": "NeonPoly",
    "visualizer": "spectrum",
    "keyboard": { "startNote": 48, "numKeys": 25 },
    "modules": [
      {
        "name": "Oscillators",
        "cols": 1,
        "controls": [
          { "id": "mix", "label": "Mix", "param": 1, "type": "knob", "min": 0, "max": 1, "step": 0.01, "val": 0.4 },
          { "id": "detune", "label": "Detune (c)", "param": 2, "type": "knob", "min": 0, "max": 20, "step": 0.5, "val": 6 },
          { "id": "noise", "label": "Noise", "param": 3, "type": "knob", "min": 0, "max": 0.3, "step": 0.01, "val": 0.05 }
        ]
      },
      {
        "name": "Filter",
        "cols": 1,
        "controls": [
          { "id": "cutoff", "label": "Cutoff", "param": 4, "type": "knob", "min": 80, "max": 12000, "curve": "log", "val": 1800 },
          { "id": "res", "label": "Res", "param": 5, "type": "knob", "min": 0.2, "max": 1.5, "step": 0.01, "val": 0.4 },
          { "id": "env_amt", "label": "Env Amt", "param": 6, "type": "knob", "min": 0, "max": 4000, "step": 10, "val": 1500 }
        ]
      },
      {
        "name": "Envelopes",
        "cols": 1,
        "controls": [
          { "id": "amp_a", "label": "Amp A", "param": 7, "type": "knob", "min": 0.002, "max": 0.2, "step": 0.001, "val": 0.01 },
