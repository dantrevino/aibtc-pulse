          { "id": "filt_r", "label": "Filt R", "param": 10, "type": "knob", "min": 0.02, "max": 1, "step": 0.01, "val": 0.3 }
        ]
      },
      {
        "name": "Modulation",
        "cols": 1,
        "controls": [
          { "id": "lfo_rate", "label": "LFO Rate", "param": 11, "type": "knob", "min": 0.1, "max": 8, "step": 0.05, "val": 1 },
